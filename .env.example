# Required in production. Used to sign session cookies.
SESSION_SECRET=replace-with-32-bytes-of-random

# Required to protect the cron endpoint. Pass as `Authorization: Bearer ...`.
CRON_SECRET=replace-with-random

# Stripe (production)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...

# Email (production) — Resend example
RESEND_API_KEY=re_...
EMAIL_FROM=alerts@clauseradar.com
