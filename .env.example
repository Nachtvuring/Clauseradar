# Supabase — Project Settings → Data API (or Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...                 # safe to expose in client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...                     # SECRET — server only, used by cron

# Cron endpoint shared secret (any random 32+ char string)
CRON_SECRET=replace-with-random

# Stripe (production)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...

# Email (production) — Resend example
RESEND_API_KEY=re_...
EMAIL_FROM=alerts@clauseradar.com
